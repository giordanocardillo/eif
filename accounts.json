    "profile": "eif-dev"
  },
  "test": {
    "provider": "aws",
    "aws_region": "us-east-1",
    "profile": "eif-test"
  },
  "prod": {
    "provider": "aws",
    "aws_region": "us-east-1",
    "assume_role_arn": "arn:aws:iam::REPLACE_WITH_ACCOUNT_ID:role/EIFDeployRole"
  },

  "azure-dev": {
    "provider": "azure",
    "subscription_id": "REPLACE_WITH_SUBSCRIPTION_ID",
