{
  "account": "test",

  "bucket_name": "YOUR_APP_NAME-assets-test",
  "s3_versioning_enabled": true,
  "cloudfront_price_class": "PriceClass_100",
  "waf_name": "YOUR_APP_NAME-waf-test",
  "waf_managed_rule_group": "AWSManagedRulesCommonRuleSet",

  "identifier": "YOUR_APP_NAME-db-test",
  "db_name": "YOUR_DB_NAME",
  "db_username": "YOUR_DB_USERNAME",
  "engine": "postgres",
  "engine_version": "15",
  "instance_class": "db.t3.small",
  "multi_az": false,

  "vpc_id": "YOUR_VPC_ID",
  "subnet_ids": ["YOUR_SUBNET_ID"],
  "allowed_cidr_blocks": ["10.0.0.0/8"],

  "function_name": "YOUR_APP_NAME-api-test",
  "runtime": "python3.12",
  "handler": "handler.lambda_handler",
  "memory_mb": 256,
  "timeout_s": 30
}
