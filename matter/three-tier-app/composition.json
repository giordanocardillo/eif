{
  "matter": "three-tier-app",
  "aws_region": "us-east-1",
  "molecules": [
    {
      "name": "swa",
      "source": "../../molecules/swa",
      "config": {
        "environment": "prod",
        "bucket_name": "my-three-tier-app-assets-prod",
        "s3_versioning_enabled": true,
        "cloudfront_price_class": "PriceClass_100",
        "waf_name": "three-tier-app-waf",
        "waf_managed_rule_group": "AWSManagedRulesCommonRuleSet"
      }
    },
    {
      "name": "db",
      "source": "../../molecules/db",
      "config": {
        "environment": "prod",
        "identifier": "three-tier-app-db",
        "db_name": "app",
        "db_username": "admin",
        "engine": "postgres",
        "engine_version": "15",
        "instance_class": "db.t3.medium",
        "multi_az": true
      }
    },
    {
      "name": "lambda_svc",
      "source": "../../molecules/lambda-svc",
      "config": {
        "environment": "prod",
        "function_name": "three-tier-app-api",
        "runtime": "python3.12",
        "handler": "handler.lambda_handler",
        "memory_mb": 512,
        "timeout_s": 30
      }
    }
  ]
}
