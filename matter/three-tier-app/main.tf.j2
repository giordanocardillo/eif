terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
  required_version = ">= 1.5"
}

provider "aws" {
  region = "{{ aws_region }}"
{% if assume_role_arn is defined %}
  assume_role {
    role_arn = "{{ assume_role_arn }}"
  }
{% elif profile is defined %}
  profile = "{{ profile }}"
{% endif %}
}

# ── Molecules ─────────────────────────────────────────────────────────────────
{% for mol in molecules %}
module "{{ mol.name }}" {
  source = "{{ mol.source }}"

{% for key, value in mol.config.items() %}
{% if value is sameas true %}
  {{ key }} = true
{% elif value is sameas false %}
  {{ key }} = false
{% elif value is string %}
  {{ key }} = "{{ value }}"
{% elif value is sequence %}
  {{ key }} = [{{ value | map('tojson') | join(', ') }}]
{% else %}
  {{ key }} = {{ value }}
{% endif %}
{% endfor %}
}
{% endfor %}

# ── Outputs ───────────────────────────────────────────────────────────────────
{% for mol in molecules %}
output "{{ mol.name }}_outputs" {
  description = "Outputs from the {{ mol.name }} molecule."
  value       = module.{{ mol.name }}
}
{% endfor %}
