{
  "matter": "three-tier-app",
  "account": "dev",
  "molecules": [
    {
      "name": "swa",
      "source": "molecules/swa",
      "config": {
        "environment": "dev",
        "bucket_name": "three-tier-app-assets-dev",
        "s3_versioning_enabled": false,
        "cloudfront_price_class": "PriceClass_100",
        "waf_name": "three-tier-app-waf-dev",
        "waf_managed_rule_group": "AWSManagedRulesCommonRuleSet"
      }
    },
    {
      "name": "db",
      "source": "molecules/db",
      "config": {
        "environment": "dev",
        "identifier": "three-tier-app-db-dev",
        "db_name": "app",
        "db_username": "admin",
        "engine": "postgres",
        "engine_version": "15",
        "instance_class": "db.t3.micro",
        "multi_az": false,
        "vpc_id": "REPLACE_WITH_DEV_VPC_ID",
        "subnet_ids": ["REPLACE_WITH_DEV_SUBNET_ID"],
        "allowed_cidr_blocks": ["10.0.0.0/8"]
      }
    },
    {
      "name": "lambda_svc",
      "source": "molecules/lambda-svc",
      "config": {
        "environment": "dev",
        "function_name": "three-tier-app-api-dev",
        "runtime": "python3.12",
        "handler": "handler.lambda_handler",
        "memory_mb": 128,
        "timeout_s": 30,
        "vpc_id": "REPLACE_WITH_DEV_VPC_ID",
        "subnet_ids": ["REPLACE_WITH_DEV_SUBNET_ID"]
      }
    }
  ]
}
